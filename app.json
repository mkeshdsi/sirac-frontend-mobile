{
  "expo": {
    "name": "Mkesh agente",
    "slug": "sirac",
    "version": "1.0.1",
    "orientation": "portrait",
    "scheme": "sirac",
    "userInterfaceStyle": "automatic",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sirac.app",
      "buildNumber": "1.0.1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs access to location to get the position of the banca.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs access to location to get the position of the banca."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logomkesh-adaptive-icon.png",
        "backgroundColor": "#F0CF12"
      },
      "usesCleartextTraffic": true,
      "package": "com.sirac.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "icon": "./assets/logomkesh-icon.png",
    "web": {
      "output": "single"
    }
  }
}
