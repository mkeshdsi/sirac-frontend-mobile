{
  "cli": {
    "version": ">= 3.14.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "android": {
        "buildType": "apk"
      },
      "channel": "production",
      "ios": {
        "simulator": true
      },
      "distribution": "internal"
    },
    "apk": {
      "android": {
        "buildType": "apk"
      },
      "channel": "production",
      "environment": "production",
      "distribution": "internal"
    },
    "pilot": {
      "android": {
        "buildType": "apk"
      },
      "channel": "pilot",
      "environment": "production",
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "pilot"
      }
    },
    "preview": {
      "android": {
        "buildType": "app-bundle"
      },
      "channel": "production",
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "channel": "production",
      "ios": {
        "buildConfiguration": "Release"
      },
      "distribution": "store"
    }
  }
}
